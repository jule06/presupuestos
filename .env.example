# Copiá este archivo como .env y completá los valores

# ID del cliente de Google OAuth2
# Crearlo en: https://console.cloud.google.com/apis/credentials
# Tipo: "ID de cliente de OAuth 2.0" → Aplicación web
# Orígenes JS autorizados: http://localhost:4200, http://localhost
# URIs de redireccionamiento: no necesarios (usa One Tap, no redirect)
GOOGLE_CLIENT_ID=tu-client-id.apps.googleusercontent.com

# Clave secreta para firmar JWT (cambiá esto en producción)
JWT_SECRET=refprice-super-secret-key-cambia-esto-en-produccion-minimo-32-chars
